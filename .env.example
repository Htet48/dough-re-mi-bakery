# ── SETUP INSTRUCTIONS ────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in YOUR Firebase project values (from Firebase Console → Project Settings)
# 3. Never commit .env — it is already listed in .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# Firebase — required (create your project at https://console.firebase.google.com)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Google Drive export — optional (https://console.cloud.google.com → APIs & Credentials)
REACT_APP_GOOGLE_API_KEY=
REACT_APP_GOOGLE_CLIENT_ID=
